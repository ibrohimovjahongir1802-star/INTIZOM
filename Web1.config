import React, { useState, useEffect, useCallback, useMemo } from "react";

/* ---------- helpers ---------- */

const pad = (n) => String(n).padStart(2, "0");

// Tizim sanasi noto'g'ri bo'lishi mumkin bo'lgani uchun, bugungi sanani aniq belgilaymiz.
// Kerak bo'lsa shu yerni o'zgartiring.
const REAL_TODAY = new Date(2026, 5, 20); // 2026-yil 20-iyun (oy 0-indeksli: 5 = iyun)

function getToday() {
return new Date(REAL_TODAY);
}

const todayKey = (d = getToday()) => `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}`;
const uzMonths = ["Yanvar","Fevral","Mart","Aprel","May","Iyun","Iyul","Avgust","Sentabr","Oktabr","Noyabr","Dekabr"];
const uzWeekdays = ["Yakshanba","Dushanba","Seshanba","Chorshanba","Payshanba","Juma","Shanba"];

function uid() {
return Math.random().toString(36).slice(2, 10);
}

function keyFromOffset(offset) {
const d = getToday();
d.setDate(d.getDate() - offset);
return todayKey(d);
}

function shortDayLabel(key) {
return key.slice(-2);
}

/* ---------- root ---------- */

export default function DisciplineApp() {
const [authLoaded, setAuthLoaded] = useState(false);
const [account, setAccount] = useState(null);
const [tasks, setTasks] = useState(null);
const [logs, setLogs] = useState({});
const [dataLoaded, setDataLoaded] = useState(false);
const [tab, setTab] = useState("tasks");
const [error, setError] = useState("");

useEffect(() => {
(async () => {
try {
const acc = await window.storage.get("account");
setAccount(acc ? JSON.parse(acc.value) : null);
} catch {
setAccount(null);
}
setAuthLoaded(true);
})();
}, []);

useEffect(() => {
if (!account) return;
(async () => {
try {
const t = await window.storage.get("tasks");
setTasks(t ? JSON.parse(t.value) : []);
} catch {
setTasks([]);
}
try {
const l = await window.storage.get("logs");
setLogs(l ? JSON.parse(l.value) : {});
} catch {
setLogs({});
}
setDataLoaded(true);
})();
}, [account]);

const saveAccount = async (acc) => {
setAccount(acc);
try {
await window.storage.set("account", JSON.stringify(acc));
} catch {
setError("Saqlashda xatolik yuz berdi.");
}
};

const saveTasks = useCallback(async (next) => {
setTasks(next);
try {
await window.storage.set("tasks", JSON.stringify(next));
} catch {
setError("Saqlashda xatolik yuz berdi.");
}
}, []);

const saveLogs = useCallback(async (next) => {
setLogs(next);
try {
await window.storage.set("logs", JSON.stringify(next));
} catch {
setError("Saqlashda xatolik yuz berdi.");
}
}, []);

const logout = async () => {
setAccount(null);
setDataLoaded(false);
try {
await window.storage.delete("account");
} catch {
/* ignore */
}
};

if (!authLoaded) {
return (
<div style={"styles.loadingScreen"}>
  <div style={"styles.loadingMark"} />
</div>
);
}

if (!account) {
return <LoginScreen onLogin={"saveAccount"} />;
}

if (!dataLoaded) {
return (
<div style={"styles.loadingScreen"}>
  <div style={"styles.loadingMark"} />
</div>
);
}

return (
<div style={"styles.page"}>
  <style>{globalCss}</style>
  <div style={"styles.bgGlow1"} />
  <div style={"styles.bgGlow2"} />

  <TopBar account={"account"} />
  {error && <div style={"styles.errorBanner"}>{error}</div>}

  <main style={"styles.main"}>
    {tab === "tasks" && (
    <TasksTab tasks={"tasks"} logs={"logs"} saveTasks={"saveTasks"} saveLogs={"saveLogs"} />
    )}
    {tab === "charts" && <ChartsTab tasks={"tasks"} logs={"logs"} />}
    {tab === "ai" && <AiTab tasks={"tasks"} logs={"logs"} />}
    {tab === "profile" && <ProfileTab account={"account"} tasks={"tasks"} logs={"logs"} onLogout={"logout"} />}
  </main>

  <BottomNav tab={"tab"} setTab={"setTab"} />
</div>
);
}

/* ---------- LOGIN ---------- */

function LoginScreen({ onLogin }) {
const [email, setEmail] = useState("");
const [password, setPassword] = useState("");
const [err, setErr] = useState("");
const [submitting, setSubmitting] = useState(false);

const submit = () => {
const trimmed = email.trim();
if (!trimmed || !trimmed.includes("@")) {
setErr("To'g'ri email kiriting.");
return;
}
if (password.length < 4) {
      setErr("Parol kamida 4 belgidan iborat bo'lsin.");
      return;
    }
    setErr("");
    setSubmitting(true);
    setTimeout(() => onLogin({ email: trimmed }), 350);
  };

  return (
    <div style={"styles.loginPage"}>
  <style>{globalCss}</style>
  <div style={"styles.loginOrb1"} />
  <div style={"styles.loginOrb2"} />
  <div style={"styles.loginOrb3"} />

  <div style={"styles.loginCard"} className="login-card-anim">
    <div style={"styles.loginBrandRow"}>
      <span style={"styles.brandDot"} />
      <span style={"styles.loginBrand"}>Intizom</span>
    </div>
    <div style={"styles.loginSubtitle"}>Kundalik maqsadlaringizni belgilang, AI bilan tahlil qiling</div>

    <div style={"styles.loginField"}>
      <label style={"styles.loginLabel"}>Email</label>
      <input
        type="email"
        style={"styles.loginInput"
        placeholder="ism@misol.com"
        value={"email"
        onChange=""{(e) ="">
        setEmail(e.target.value)}
        onKeyDown={(e) => e.key === "Enter" && submit()}
        />
      </div>

    <div style={"styles.loginField"}>
      <label style={"styles.loginLabel"}>Parol</label>
      <input
        type="password"
        style={"styles.loginInput"
        placeholder="••••••••"
        value={"password"
        onChange=""{(e) ="">
        setPassword(e.target.value)}
        onKeyDown={(e) => e.key === "Enter" && submit()}
        />
      </div>

    {err && <div style={"styles.loginError"}>{err}</div>}

    <button style={"styles.loginBtn"} onClick={"submit"} disabled={"submitting"}>
      {submitting ? "Kirilyapti…" : "Kirish"}
    </button>
    <div style={"styles.loginNote"}>
      Hisobingiz shu qurilmada saqlanadi. Server ulanishi keyinroq qo'shiladi.
    </div>
  </div>
</div>
);
}

/* ---------- TOP BAR & BOTTOM NAV ---------- */

function TopBar({ account }) {
return (
<header style={"styles.header"}>
  <div style={"styles.headerTop"}>
    <span style={"styles.brandDot"} />
    <span style={"styles.brand"}>Intizom</span>
  </div>
  <div style={"styles.headerEmail"}>{account.email}</div>
</header>
);
}

function BottomNav({ tab, setTab }) {
const items = [
{ id: "tasks", label: "Vazifalar", icon: "✓" },
{ id: "charts", label: "Grafiklar", icon: "📈" },
{ id: "ai", label: "AI Tahlil", icon: "✦" },
{ id: "profile", label: "Profil", icon: "◍" },
];
return (
<nav style={"styles.bottomNav"}>
  {items.map((it) => {
  const active = tab === it.id;
  return (
  <button
    key={"it.id"
    onClick=""{() =>
    setTab(it.id)}
    style={{ ...styles.navItem, color: active ? BLUE : TEXT_DIM }}
    >
    <span style={{ "...styles.navIcon", opacity:="" active="" ? 1="" :="" 0.6="" }}>{it.icon}</span>
    <span style={"styles.navLabel"}>{it.label}</span>
    {active && <span style={"styles.navUnderline"} />}
  </button>
  );
  })}
</nav>
);
}

/* ---------- TASKS TAB ---------- */

function TasksTab({ tasks, logs, saveTasks, saveLogs }) {
const [newTaskName, setNewTaskName] = useState("");
const [adding, setAdding] = useState(false);
const [pulse, setPulse] = useState(null);

const todayK = todayKey();
const last30Keys = useMemo(() => {
const arr = [];
for (let i = 29; i >= 0; i--) arr.push(keyFromOffset(i));
return arr; // oldest -> newest, today is last (rightmost)
}, [todayK]);

const addTask = () => {
const name = newTaskName.trim();
if (!name) return;
const next = [...(tasks || []), { id: uid(), name, createdAt: todayK }];
saveTasks(next);
setNewTaskName("");
setAdding(false);
};

const removeTask = (id) => {
const next = (tasks || []).filter((t) => t.id !== id);
saveTasks(next);
};

const setStatus = (taskId, dayKey, isFuture) => {
if (isFuture) return;
const dayLogs = { ...(logs[dayKey] || {}) };
const cur = dayLogs[taskId];
let next;
if (cur === true) next = false;
else if (cur === false) next = undefined;
else next = true;

if (next === undefined) delete dayLogs[taskId];
else dayLogs[taskId] = next;

saveLogs({ ...logs, [dayKey]: dayLogs });

if (next === true) {
setPulse(`${taskId}-${dayKey}-done`);
setTimeout(() => setPulse(null), 450);
} else if (next === false) {
setPulse(`${taskId}-${dayKey}-miss`);
setTimeout(() => setPulse(null), 450);
}
};

return (
<div className="fade-in">
  <div style={"styles.tasksSectionHeader"}>
    <div style={"styles.sectionLabel"}>Vazifalarim</div>
    {!adding && (
    <button style={"styles.addBtn"} onClick=""{() => setAdding(true)}>+ Vazifa</button>
    )}
  </div>

  {adding && (
  <div style={"styles.addRow"} className="slide-down">
    <input
      autoFocus=""
      style={"styles.addInput"
      placeholder="Masalan: Kuniga 10 bet kitob o'qish"
      value={"newTaskName"
      onChange=""{(e) ="">
      setNewTaskName(e.target.value)}
      onKeyDown={(e) => {
      if (e.key === "Enter") addTask();
      if (e.key === "Escape") {
      setAdding(false);
      setNewTaskName("");
      }
      }}
      />
      <button style={"styles.addConfirm"} onClick={"addTask"}>Qo'shish</button>
      <button
        style={"styles.addCancel"
        onClick=""{() =>
        {
        setAdding(false);
        setNewTaskName("");
        }}
        >
        Bekor
      </button>
    </div>
  )}

  {tasks && tasks.length === 0 && !adding && (
  <div style={"styles.emptyState"}>
    Hali vazifa yo'q. Birinchi intizom maqsadingizni qo'shing — masalan, kuniga 10 bet kitob o'qish.
  </div>
  )}

  {tasks && tasks.length > 0 && (
  <div style={"styles.taskList"}>
    {tasks.map((task, idx) => (
    <TaskRow30
      key={"task.id"
      task={"task"
      dayKeys={"last30Keys"
      logs={"logs"
      todayK={"todayK"
      pulse={"pulse"
      onToggle={"setStatus"
      onRemove={"removeTask"
      delay={"idx" * 60=""}
            />
    ))}
  </div>
  )}
</div>
);
}

function TaskRow30({ task, dayKeys, logs, todayK, pulse, onToggle, onRemove, delay }) {
const [hovered, setHovered] = useState(false);
const scrollRef = React.useRef(null);
const status = (key) => (logs[key] || {})[task.id];

const doneCount = dayKeys.filter((k) => status(k) === true).length;

// auto-scroll to the end (today) on mount
useEffect(() => {
if (scrollRef.current) {
scrollRef.current.scrollLeft = scrollRef.current.scrollWidth;
}
}, []);

return (
<div
  style={{ "...styles.taskCard", animationDelay:=""
  className="card-rise"
  onMouseEnter=""{() =>
  setHovered(true)}
  onMouseLeave={() => setHovered(false)}
  >
  <div style={"styles.taskCardTop"}>
    <div>
      <div style={"styles.taskName"}>{task.name}</div>
      <div style={"styles.taskMeta"}>{doneCount}/30 kun bajarildi</div>
    </div>
    {hovered && (
    <button style={"styles.removeBtn"} onClick=""{() => onRemove(task.id)}>✕ o'chirish</button>
    )}
  </div>

  <div style={"styles.row30Scroll"} ref={"scrollRef"}>
    <div style={"styles.row30"}>
      {dayKeys.map((key) => {
      const st = status(key);
      const isFuture = key > todayK;
      const isToday = key === todayK;
      const isPulsing = pulse === `${task.id}-${key}-${st === true ? "done" : "miss"}`;

      let bg = SURFACE_2;
      let border = `1px solid ${BORDER}`;
      let color = TEXT_DIM;
      let content = "";

      if (st === true) {
      bg = GREEN;
      border = `1px solid ${GREEN}`;
      color = "#062012";
      content = "✓";
      } else if (st === false) {
      bg = RED;
      border = `1px solid ${RED}`;
      color = "#2a0707";
      content = "✕";
      } else if (isFuture) {
      bg = "transparent";
      border = `1px dashed ${BORDER}`;
      color = "#3a4456";
      }

      return (
      <button
        key={"key"
        disabled={"isFuture"
        title={"key"
        onClick=""{() =>
        onToggle(task.id, key, isFuture)}
        style={{
        ...styles.dayCell30,
        background: bg,
        border,
        color,
        cursor: isFuture ? "default" : "pointer",
        outline: isToday ? `2px solid ${BLUE}` : "none",
        outlineOffset: isToday ? "1px" : "0",
        transform: isPulsing ? "scale(1.2)" : "scale(1)",
        boxShadow: isToday ? `0 0 0 4px rgba(59,130,246,0.15)` : "none",
        }}
        >
        <span style={"styles.dayCell30Mark"}>{content}</span>
        <span style={"styles.dayCell30Label"}>{shortDayLabel(key)}</span>
      </button>
      );
      })}
    </div>
  </div>
</div>
);
}

/* ---------- CHARTS TAB ---------- */

function ChartsTab({ tasks, logs }) {
const [viewDate, setViewDate] = useState(getToday());
const year = viewDate.getFullYear();
const month = viewDate.getMonth();
const totalDays = new Date(year, month + 1, 0).getDate();
const isCurrentMonth =
`${year}-${pad(month + 1)}` === `${getToday().getFullYear()}-${pad(getToday().getMonth() + 1)}`;

const stats = useMemo(() => {
if (!tasks || tasks.length === 0) return { percent: 0, done: 0, possible: 0, perDay: [] };
let done = 0;
let possible = 0;
const perDay = [];
const lastDay = isCurrentMonth ? getToday().getDate() : totalDays;

for (let d = 1; d <= totalDays; d++) {
const key = `${year}-${pad(month + 1)}-${pad(d)}`;
const dayLog = logs[key] || {};
if (d <= lastDay) {
let dayDone = 0;
tasks.forEach((t) => {
possible += 1;
if (dayLog[t.id] === true) {
done += 1;
dayDone += 1;
}
});
perDay.push(tasks.length ? dayDone / tasks.length : 0);
} else {
perDay.push(null);
}
}
const percent = possible > 0 ? Math.round((done / possible) * 100) : 0;
return { percent, done, possible, perDay };
}, [tasks, logs, year, month, totalDays, isCurrentMonth]);

const streak = useMemo(() => {
if (!tasks || tasks.length === 0) return 0;
let count = 0;
let cursor = getToday();
while (true) {
const key = todayKey(cursor);
const dayLog = logs[key] || {};
const allDone = tasks.every((t) => dayLog[t.id] === true);
if (allDone) {
count += 1;
cursor.setDate(cursor.getDate() - 1);
} else break;
}
return count;
}, [tasks, logs]);

const changeMonth = (delta) => {
const d = new Date(viewDate);
d.setDate(1);
d.setMonth(d.getMonth() + delta);
setViewDate(d);
};

return (
<div className="fade-in">
  <section style={"styles.hero"}>
    <div style={"styles.heroPercentBlock"}>
      <div style={"styles.heroPercent"}>
        {stats.percent}
        <span style={"styles.heroPercentSign"}>%</span>
      </div>
      <div style={"styles.heroLabel"}>{uzMonths[month]} oyida bajarilgan</div>
    </div>
    <div style={"styles.heroStats"}>
      <StatPill label="ketma-ket kun" value={"streak"} color={"BLUE"} />
      <StatPill label="bajarilgan" value={"stats.done"} color={"GREEN"} />
      <StatPill label="jami imkoniyat" value={"stats.possible"} color="#64748b" />
    </div>
  </section>

  <div style={"styles.monthNav"}>
    <button style={"styles.navBtn"} onClick=""{() => changeMonth(-1)} aria-label="Oldingi oy">‹</button>
    <div style={"styles.monthTitle"}>{uzMonths[month]} {year}</div>
    <button
      style={{ "...styles.navBtn", opacity:="" isCurrentMonth="" ? 0.3="" :="" 1="", pointerEvents:="" isCurrentMonth="" ? "none" :=""
      onClick=""{() =>
      changeMonth(1)}
      aria-label="Keyingi oy"
      >
      ›
    </button>
  </div>

  <div style={"styles.sectionLabel"}>Oylik intizom darajasi</div>
  <MonthChart perDay={"stats.perDay"} totalDays={"totalDays"} />

  {tasks && tasks.length > 0 && (
  <div style={{ "marginTop:" 28="" }}>
    <div style={"styles.sectionLabel"}>Vazifalar bo'yicha taqsimot</div>
    <TaskBreakdown tasks={"tasks"} logs={"logs"} year={"year"} month={"month"} totalDays={"totalDays"} isCurrentMonth={"isCurrentMonth"} />
  </div>
  )}
</div>
);
}

function TaskBreakdown({ tasks, logs, year, month, totalDays, isCurrentMonth }) {
const lastDay = isCurrentMonth ? getToday().getDate() : totalDays;
return (
<div style={"styles.breakdownList"}>
  {tasks.map((t) => {
  let done = 0;
  for (let d = 1; d <= lastDay; d++) {
  const key = `${year}-${pad(month + 1)}-${pad(d)}`;
  if ((logs[key] || {})[t.id] === true) done += 1;
  }
  const pct = lastDay > 0 ? Math.round((done / lastDay) * 100) : 0;
  return (
  <div key={`t.id`} style={`styles.breakdownRow`}>
    <div style={`styles.breakdownTop`}>
      <span style={`styles.breakdownName`}>{t.name}</span>
      <span style={`styles.breakdownPct`}>{pct}%</span>
    </div>
    <div style={`styles.breakdownBarBg`}>
      <div style={{ `...styles.breakdownBarFill`, width:=`` `${pct}%` }} />
    </div>
  </div>
  );
  })}
</div>
);
}

function MonthChart({ perDay, totalDays }) {
const width = 600;
const height = 160;
const padding = { top: 14, right: 10, bottom: 24, left: 10 };
const innerW = width - padding.left - padding.right;
const innerH = height - padding.top - padding.bottom;

const validPoints = perDay.map((v, i) => ({ v, i })).filter((p) => p.v !== null);

const points = validPoints.map((p) => {
const x = padding.left + (p.i / Math.max(totalDays - 1, 1)) * innerW;
const y = padding.top + (1 - p.v) * innerH;
return { x, y, raw: p.v, day: p.i + 1 };
});

const linePath = points.map((p, idx) => `${idx === 0 ? "M" : "L"} ${p.x.toFixed(2)} ${p.y.toFixed(2)}`).join(" ");

const areaPath =
points.length > 0
? `${linePath} L ${points[points.length - 1].x.toFixed(2)} ${(padding.top + innerH).toFixed(2)} L ${points[0].x.toFixed(2)} ${(padding.top + innerH).toFixed(2)} Z`
: "";

return (
<div style={`styles.chartWrap`}>
  <svg viewBox={`0 0 ${width} ${height}`} style={`styles.chartSvg`} preserveAspectRatio="none">
    <defs>
      <linearGradient id="areaFill" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stopColor={"BLUE"} stopOpacity="0.35" />
        <stop offset="100%" stopColor={"BLUE"} stopOpacity="0" />
      </linearGradient>
    </defs>

    {[0, 0.5, 1].map((g) => (
    <line
      key={"g"
      x1={"padding.left"
      x2={"width" -="" padding.right=""
      y1={"padding.top" + (1="" -="" g="") * innerH=""
      y2={"padding.top" + (1="" -="" g="") * innerH=""
      stroke={"BORDER"
      strokeWidth="1"
      strokeDasharray=""{g =""== 0="" ? "0" :="" "3,4"}
          />
    ))}

    {areaPath && <path d={"areaPath"} fill="url(#areaFill)" />}
    {linePath && (
    <path d={"linePath"} fill="none" stroke={"BLUE"} strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round" />
    )}

    {points.map((p) => (
    <circle
      key={"p.day"
      cx={"p.x"
      cy={"p.y"
      r=""{p.raw =""== 1="" ? 4="" :="" 3=""
      fill=""{p.raw =""== 0="" ? RED="" :="" p.raw =""== 1="" ? GREEN="" :="" BLUE=""
      opacity=""{p.raw =""== 0="" ? 0.7="" :="" 1=""}
          />
    ))}
  </svg>
  <div style={"styles.chartAxisLabels"}>
    <span>1-kun</span>
    <span>{totalDays}-kun</span>
  </div>
</div>
);
}

function StatPill({ label, value, color }) {
return (
<div style={"styles.statPill"}>
  <span style={{ "...styles.statPillValue", color="" }}>{value}</span>
  <span style={"styles.statPillLabel"}>{label}</span>
</div>
);
}

/* ---------- AI TAHLIL TAB ---------- */

function buildAnalysisPayload(tasks, logs) {
// last 30 days, grouped by weekday, to give the model structured behavioral data
const todayK = todayKey();
const days = [];
for (let i = 29; i >= 0; i--) {
const d = getToday();
d.setDate(d.getDate() - i);
const key = todayKey(d);
const dayLog = logs[key] || {};
const total = tasks.length;
const done = tasks.filter((t) => dayLog[t.id] === true).length;
const missed = tasks.filter((t) => dayLog[t.id] === false).length;
days.push({
date: key,
weekday: uzWeekdays[d.getDay()],
done,
missed,
total,
rate: total > 0 ? Math.round((done / total) * 100) : null,
});
}
return { todayK, days, taskNames: tasks.map((t) => t.name) };
}

function AiTab({ tasks, logs }) {
const [status, setStatus] = useState("idle"); // idle | loading | done | error
const [analysis, setAnalysis] = useState(null);
const [errMsg, setErrMsg] = useState("");

const hasEnoughData = tasks && tasks.length > 0;

const runAnalysis = useCallback(async () => {
if (!hasEnoughData) return;
setStatus("loading");
setErrMsg("");
try {
const payload = buildAnalysisPayload(tasks, logs);

const systemPrompt = `Sen shaxsiy intizom (habit tracking) bo'yicha o'zbek tilida maslahat beruvchi tahlilchisan. Foydalanuvchi oxirgi 30 kunlik vazifa bajarish tarixini (JSON formatda) beraman. Vazifa: shu ma'lumotlarni tahlil qilib, QAYSI HAFTA KUNLARIDA yoki QAYSI VAQT ICHIDA (oy boshi/o'rtasi/oxiri) foydalanuvchi ko'proq "dangasalik" qilgani (bajarmagan/missed bo'lgan kunlar) va qaysi paytlarda eng barqaror/aniq ishlagani (done bo'lgan kunlar) haqida xulosa chiqarish. Faqat berilgan ma'lumotlarga asoslan, taxmin qilmagan holda real naqshlarni top. Agar ma'lumot juda kam bo'lsa (masalan hammasi bo'sh), shuni aytib, umumiy motivatsion maslahat ber.

JAVOBNI FAQAT shu JSON formatda qaytar, boshqa hech narsa yozma (markdown belgilarsiz, izohlarsiz):
{
"weakest_period": "qisqa ibora, masalan 'Dam olish kunlari (shanba-yakshanba)'",
"strongest_period": "qisqa ibora, masalan 'Hafta boshida (dushanba-seshanba)'",
"summary": "2-3 gapli umumiy tahlil, samimiy ohangda, o'zbek tilida",
"advice": ["amaliy maslahat 1", "amaliy maslahat 2", "amaliy maslahat 3"],
"discipline_score_comment": "bajarish foiziga oid 1 gaplik sharh"
}`;

const response = await fetch("https://api.anthropic.com/v1/messages", {
method: "POST",
headers: { "Content-Type": "application/json" },
body: JSON.stringify({
model: "claude-sonnet-4-6",
max_tokens: 1000,
system: systemPrompt,
messages: [
{
role: "user",
content: `Bugungi sana: ${payload.todayK}. Vazifalar: ${JSON.stringify(payload.taskNames)}. Oxirgi 30 kunlik tarix: ${JSON.stringify(payload.days)}`,
},
],
}),
});

const data = await response.json();
const textBlock = (data.content || []).find((c) => c.type === "text");
const raw = textBlock ? textBlock.text : "";
const clean = raw.replace(/```json|```/g, "").trim();
const parsed = JSON.parse(clean);
setAnalysis(parsed);
setStatus("done");
} catch (e) {
setErrMsg("Tahlil qilishda xatolik yuz berdi. Birozdan keyin qayta urinib ko'ring.");
setStatus("error");
}
}, [tasks, logs, hasEnoughData]);

useEffect(() => {
if (hasEnoughData) {
runAnalysis();
} else {
setStatus("idle");
}
// eslint-disable-next-line react-hooks/exhaustive-deps
}, [hasEnoughData]);

if (!hasEnoughData) {
return (
<div className="fade-in">
  <div style={"styles.sectionLabel"}>AI Tahlilchi</div>
  <div style={"styles.emptyState"}>
    AI tahlil qilishi uchun avval "Vazifalar" bo'limida kamida bitta vazifa qo'shing.
  </div>
</div>
);
}

return (
<div className="fade-in">
  <div style={"styles.tasksSectionHeader"}>
    <div style={"styles.sectionLabel"}>AI Tahlilchi</div>
    <button style={"styles.addBtn"} onClick={"runAnalysis"} disabled=""{status =""== "loading"}>
      {status === "loading" ? "Tahlil qilinmoqda…" : "↻ Qayta tahlil"}
    </button>
  </div>

  {status === "loading" && (
  <div style={"styles.aiLoadingCard"} className="card-rise">
    <div style={"styles.aiSpinner"} />
    <div style={"styles.aiLoadingText"}>Sun'iy intellekt sizning 30 kunlik harakatlaringizni o'rganmoqda…</div>
  </div>
  )}

  {status === "error" && (
  <div style={"styles.loginError"}>{errMsg}</div>
  )}

  {status === "done" && analysis && (
  <div style={"styles.aiResultWrap"}>
    <div style={"styles.aiSummaryCard"} className="card-rise glow-border">
      <div style={"styles.aiSummaryIcon"}>✦</div>
      <div style={"styles.aiSummaryText"}>{analysis.summary}</div>
    </div>

    <div style={"styles.aiPeriodGrid"}>
      <div style={{ "...styles.aiPeriodCard", borderColor:="" "rgba(239,68,68,0.35)" }} className="card-rise">
        <div style={{ "...styles.aiPeriodLabel", color:="" RED="" }}>Eng zaif davr</div>
        <div style={"styles.aiPeriodValue"}>{analysis.weakest_period}</div>
      </div>
      <div style={{ "...styles.aiPeriodCard", borderColor:="" "rgba(34,197,94,0.35)" }} className="card-rise">
        <div style={{ "...styles.aiPeriodLabel", color:="" GREEN="" }}>Eng kuchli davr</div>
        <div style={"styles.aiPeriodValue"}>{analysis.strongest_period}</div>
      </div>
    </div>

    {analysis.discipline_score_comment && (
    <div style={"styles.aiScoreComment"} className="card-rise">{analysis.discipline_score_comment}</div>
    )}

    <div style={"styles.sectionLabel"}>Maslahatlar</div>
    <div style={"styles.aiAdviceList"}>
      {(analysis.advice || []).map((a, i) => (
      <div key={"i"} style={"styles.aiAdviceRow"} className="card-rise" >
        <span style={"styles.aiAdviceBullet"}>{i + 1}</span>
        <span style={"styles.aiAdviceText"}>{a}</span>
      </div>
      ))}
    </div>
  </div>
  )}
</div>
);
}

/* ---------- PROFILE TAB ---------- */

function ProfileTab({ account, tasks, logs, onLogout }) {
const totalTasks = tasks ? tasks.length : 0;
const totalChecks = useMemo(() => {
let c = 0;
Object.values(logs).forEach((dayLog) => {
Object.values(dayLog).forEach((v) => {
if (v === true) c += 1;
});
});
return c;
}, [logs]);

const streak = useMemo(() => {
if (!tasks || tasks.length === 0) return 0;
let count = 0;
let cursor = getToday();
while (true) {
const key = todayKey(cursor);
const dayLog = logs[key] || {};
const allDone = tasks.every((t) => dayLog[t.id] === true);
if (allDone) {
count += 1;
cursor.setDate(cursor.getDate() - 1);
} else break;
}
return count;
}, [tasks, logs]);

return (
<div className="fade-in">
  <div style={"styles.profileCard"}>
    <div style={"styles.profileAvatar"}>{account.email[0].toUpperCase()}</div>
    <div style={"styles.profileEmail"}>{account.email}</div>
  </div>

  <div style={"styles.profileStatsGrid"}>
    <ProfileStat label="Faol vazifalar" value={"totalTasks"} color={"BLUE"} />
    <ProfileStat label="Jami bajarilgan" value={"totalChecks"} color={"GREEN"} />
    <ProfileStat label="Ketma-ket kun" value={"streak"} color="#f59e0b" />
  </div>

  <button style={"styles.logoutBtn"} onClick={"onLogout"}>Chiqish</button>
</div>
);
}

function ProfileStat({ label, value, color }) {
return (
<div style={"styles.profileStatCard"} className="card-rise">
  <div style={{ "...styles.profileStatValue", color="" }}>{value}</div>
  <div style={"styles.profileStatLabel"}>{label}</div>
</div>
);
}


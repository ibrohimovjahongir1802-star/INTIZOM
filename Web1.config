const globalCss = `
* { box-sizing: border-box; }
body { background: ${BG}; }
button { font-family: inherit; }
button:focus-visible, input:focus-visible {
outline: 2px solid ${BLUE};
outline-offset: 2px;
}
input:focus {
border-color: ${BLUE} !important;
background: rgba(59,130,246,0.06) !important;
}
button:active { transform: scale(0.97); }

@keyframes spin { to { transform: rotate(360deg); } }
@keyframes float1 {
0%, 100% { transform: translate(0,0); }
50% { transform: translate(20px, -24px); }
}
@keyframes float2 {
0%, 100% { transform: translate(0,0); }
50% { transform: translate(-24px, 20px); }
}
@keyframes fadeIn {
from { opacity: 0; transform: translateY(6px); }
to { opacity: 1; transform: translateY(0); }
}
@keyframes slideDown {
from { opacity: 0; transform: translateY(-8px); }
to { opacity: 1; transform: translateY(0); }
}
@keyframes cardRise {
from { opacity: 0; transform: translateY(14px); }
to { opacity: 1; transform: translateY(0); }
}
@keyframes glowPulse {
0%, 100% { box-shadow: 0 0 0 0 rgba(59,130,246,0.0); }
50% { box-shadow: 0 0 24px 0 rgba(59,130,246,0.18); }
}
.fade-in { animation: fadeIn 0.35s ease both; }
.slide-down { animation: slideDown 0.25s ease both; }
.card-rise { animation: cardRise 0.4s cubic-bezier(.2,.8,.2,1) both; }
.glow-border { animation: cardRise 0.4s cubic-bezier(.2,.8,.2,1) both, glowPulse 3.5s ease-in-out infinite; }
.login-card-anim { animation: cardRise 0.5s cubic-bezier(.2,.8,.2,1) both; }

::-webkit-scrollbar { height: 6px; }
::-webkit-scrollbar-thumb { background: ${BORDER}; border-radius: 3px; }

@media (prefers-reduced-motion: reduce) {
* { transition: none !important; animation: none !important; }
}
`;